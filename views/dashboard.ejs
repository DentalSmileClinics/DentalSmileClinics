<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Account - BrightSmile</title>
    <link rel="stylesheet" href="/dashboard.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;700&display=swap"
        rel="stylesheet">
</head>

<body class="patient-dash">

    <aside class="sidebar">
        <div class="sidebar-brand">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C9.5 2 7.5 3.5 6.5 5.5C5.5 4.5 4 4 3 5C1.5 6.5 2 9 3 11C4 13 5 15 5 18C5 20 6 22 8 22C9 22 10 21 10.5 20C11 21 11.5 22 12 22C12.5 22 13 21 13.5 20C14 21 15 22 16 22C18 22 19 20 19 18C19 15 20 13 21 11C22 9 22.5 6.5 21 5C20 4 18.5 4.5 17.5 5.5C16.5 3.5 14.5 2 12 2Z"/></svg>
            BrightSmile
        </div>
        <nav class="sidebar-nav">
            <a href="#overview" class="slink active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Overview
            </a>
            <a href="#book" class="slink">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Book Appointment
            </a>
            <a href="#history" class="slink">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                My Appointments
            </a>
            <a href="#profile" class="slink">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                My Profile
            </a>
        </nav>
        <a href="/logout" class="sidebar-logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
        </a>
    </aside>

    <main class="dash-main">
        <header class="dash-topbar">
            <div>
                <h2 class="dash-greeting">Good day,
                    <%= user.first_name + ' ' + user.last_name %>!
                </h2>
                <p class="dash-sub">Here's your dental care summary.</p>
            </div>
            <div class="topbar-avatar">
                <%= user.first_name.substring(0, 1) + user.last_name.substring(0, 1) %>
            </div>
        </header>

        <section id="overview" class="dash-section">
            <div class="dash-cards">
                <div class="dcard teal">
                    <div class="dcard-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div>
                        <p class="dcard-label">Next Appointment</p>
                        <p class="dcard-value">
                            <% if (next_appt) { %>
                                <%= new Date(next_appt.appointment_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                            <% } else { %>
                                None
                            <% } %>
                        </p>
                    </div>
                </div>
                <div class="dcard blue">
                    <div class="dcard-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div>
                        <p class="dcard-label">Completed Visits</p>
                        <p class="dcard-value"><%= stats.total_visits %></p>
                    </div>
                </div>
                <div class="dcard orange">
                    <div class="dcard-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                    </div>
                    <div>
                        <p class="dcard-label">Upcoming Sessions</p>
                        <p class="dcard-value"><%= stats.upcoming %></p>
                    </div>
                </div>
                <div class="dcard green">
                    <div class="dcard-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div>
                        <p class="dcard-label">Member Status</p>
                        <p class="dcard-value">Active</p>
                    </div>
                </div>
            </div>

            <% if (!next_appt && stats.total_visits == 0) { %>
                <div class="welcome-box">
                    <div class="welcome-icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C9.5 2 7.5 3.5 6.5 5.5C5.5 4.5 4 4 3 5C1.5 6.5 2 9 3 11C4 13 5 15 5 18C5 20 6 22 8 22C9 22 10 21 10.5 20C11 21 11.5 22 12 22C12.5 22 13 21 13.5 20C14 21 15 22 16 22C18 22 19 20 19 18C19 15 20 13 21 11C22 9 22.5 6.5 21 5C20 4 18.5 4.5 17.5 5.5C16.5 3.5 14.5 2 12 2Z"/></svg>
                    </div>
                    <div class="welcome-text">
                        <h3>Welcome to BrightSmile</h3>
                        <p>You haven't booked a dental session yet. Schedule your first appointment and begin your journey to better oral health.</p>
                        <button onclick="document.querySelector('[href=\'#book\']').click()" class="btn-primary">Schedule an Appointment</button>
                    </div>
                </div>
            <% } %>

            <div class="table-card">
                <div class="table-header">
                    <h3>My Recent Sessions</h3>
                    <a href="#history" class="view-all">View All</a>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Service</th>
                            <th>Dentist</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (appointments && appointments.length > 0) { %>
                            <% appointments.forEach(function(row) { %>
                                <tr>
                                     <td><strong><%= services_map[row.service_id] || 'Consultation' %></strong></td>
                                    <td>Dentist <%= row.dentist_id || '1' %></td>
                                    <td><%= new Date(row.appointment_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                                    <td><%= row.appointment_time %></td>
                                    <td><span class="status-pill <%= row.status.toLowerCase() %>"><%= row.status.charAt(0).toUpperCase() + row.status.slice(1) %></span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="empty-state">
                                    <div class="empty-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="12" y2="18"/></svg>
                                    </div>
                                    <p>No appointment records found.</p>
                                    <small>Your visit history will appear here once an appointment is made.</small>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- BOOK APPOINTMENT -->
        <section id="book" class="dash-section hidden">
            <div class="form-panel">
                <h3>Request an Appointment</h3>
                <p class="form-hint">Choose your preferred service and schedule. Our staff will confirm your booking.
                </p>
                <form id="appointment-form">
                    <div class="field-row">
                        <div class="field">
                            <label>Service</label>
                            <select name="service_id" id="service-select" required>
                                <option value="">-- Select treatment --</option>
                                <% services.forEach(function(s) { 
                                    let price_display = '';
                                    if (s.min_price && s.max_price) {
                                        if (s.min_price == s.max_price) {
                                            price_display = "₱" + parseInt(s.min_price).toLocaleString();
                                        } else {
                                            price_display = "₱" + parseInt(s.min_price).toLocaleString() + " - ₱" + parseInt(s.max_price).toLocaleString();
                                        }
                                    } else if (s.min_price) {
                                        price_display = "Starting at ₱" + parseInt(s.min_price).toLocaleString();
                                    } else if (s.price) {
                                        price_display = "₱" + parseInt(s.price).toLocaleString();
                                    } else {
                                        price_display = "Price varies upon assessment";
                                    }
                                %>
                                    <option value="<%= s.service_id %>" data-price="<%= price_display %>"><%= s.service_name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="field">
                            <label>Preferred Dentist</label>
                            <select name="dentist_id" required>
                                <option value="1">Dentist 1</option>
                                <option value="2">Dentist 2</option>
                                <option value="3">Dentist 3</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field"><label>Preferred Date</label><input type="date" name="date" required
                                min="<%= new Date().toISOString().split('T')[0] %>"></div>
                        <div class="field">
                            <label>Preferred Time</label>
                            <select name="time" required>
                                <option>8:00 AM</option>
                                <option>9:00 AM</option>
                                <option>10:00 AM</option>
                                <option>11:00 AM</option>
                                <option>1:00 PM</option>
                                <option>2:00 PM</option>
                                <option>3:00 PM</option>
                                <option>4:00 PM</option>
                            </select>
                        </div>
                    </div>
                    <div id="price-indicator" class="price-indicator hidden">
                        <span>Estimated Cost:</span>
                        <strong id="price-value">0</strong>
                    </div>
                    <button type="submit" class="btn-primary">Confirm My Booking</button>
                </form>
            </div>
        </section>

        <!-- PROFILE -->
        <section id="profile" class="dash-section hidden">
            <div class="form-panel">
                <h3>My Profile</h3>
                <div class="field-row">
                    <div class="field"><label>First Name</label><input type="text"
                            value="<%= user.first_name %>" readonly></div>
                    <div class="field"><label>Last Name</label><input type="text"
                            value="<%= user.last_name %>" readonly></div>
                </div>
                <div class="field"><label>Email Address</label><input type="email"
                        value="<%= cust ? cust.email : '' %>" readonly></div>
                <div class="field"><label>Contact Number</label><input type="text"
                        value="<%= cust ? cust.contact_number : '' %>" readonly></div>
                <div class="field"><label>Date of Birth</label><input type="text"
                        value="<%= cust && cust.date_of_birth ? new Date(cust.date_of_birth).toISOString().split('T')[0] : '' %>" readonly></div>
            </div>
        </section>

    </main>

    <script src="/dashboard.js"></script>
</body>

</html>
